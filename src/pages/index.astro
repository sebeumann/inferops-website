---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { slugifyStr } from "@/utils/slugify";
import { Image } from "astro:assets";
import profileImg from "@/assets/images/profile-sebastian-eumann.png";

// ── Editable content ──────────────────────────────────────────────────────────
const HEADLINE =
  "From GPU clusters to inference pipelines: what it actually takes to run AI in production.";
const CONTACT_EMAIL = "sebastian@inferops.dev";
const GITHUB_URL = "https://github.com/sebeumann";
const X_URL = "https://x.com/sebeumann";
// ─────────────────────────────────────────────────────────────────────────────

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const recentPosts = sortedPosts.slice(0, 5);

function fmtDate(date: Date): string {
  return new Date(date).toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
  });
}
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <div class="mx-auto max-w-[680px]">
      <!-- 1. Hero -->
      <section id="hero" class="border-b border-border pt-12 pb-10">
        <div class="flex items-start justify-between gap-6">
          <div class="flex-1">
            <h1
              class="mb-4 text-[22px] font-medium tracking-[-0.3px] text-foreground"
            >
              {HEADLINE}
            </h1>
            <p class="mb-5 text-[15px] leading-[1.7] text-foreground/65">
              {
                "I build and architect enterprise-grade AI infrastructure, on-premise and in the cloud. From production ready GPU clusters, LLM serving, RAG and agentic pipelines, MLOps, LLMOps, CI/CD, to full platform and AI system engineering. This blog is about the things nobody warns you about: building for production, and keeping it there."
              }
            </p>
            <div class="flex gap-5 text-[13px]">
              <a
                href={GITHUB_URL}
                class="border-b border-foreground/30 pb-px text-foreground/65 transition-colors hover:border-foreground/60"
              >
                GitHub
              </a>
              <a
                href={X_URL}
                class="border-b border-foreground/30 pb-px text-foreground/65 transition-colors hover:border-foreground/60"
              >
                X
              </a>
              <a
                href={`mailto:${CONTACT_EMAIL}`}
                class="border-b border-foreground/30 pb-px text-foreground/65 transition-colors hover:border-foreground/60"
              >
                Email
              </a>
            </div>
          </div>
          <Image
            src={profileImg}
            alt="Profile photo"
            width={212}
            height={212}
            class="-mt-1 hidden h-53 w-53 shrink-0 rounded-full object-cover sm:block"
          />
        </div>
      </section>

      <!-- 2. Work with me -->
      <section id="work-with-me" class="border-b border-border pt-8 pb-10">
        <p
          class="mb-4 text-[16px] font-medium tracking-[0.8px] text-foreground uppercase"
        >
          WORK WITH ME
        </p>
        <p class="mb-4 text-[15px] leading-[1.7] text-foreground/65">
          {
            "If you want to figure things out yourself, the blog is here for that. Real problems and real solutions."
          }
        </p>
        <p class="mb-4 text-[15px] leading-[1.7] text-foreground/65">
          {
            "If you need someone to actually build it, I help enterprises design and implement AI platforms, inference infrastructure, and MLOps pipelines from architecture to production. Cloud-native engineering, Kubernetes, GPU scheduling, model serving, monitoring and observability, CI/CD for ML workloads, infrastructure as code, and the DevOps glue that holds it all together."
          }
        </p>
        <p class="text-[15px] leading-[1.7] text-foreground/65">
          {"Feel free to reach out on "}
          <a
            href={X_URL}
            class="border-b border-foreground/50 pb-px text-foreground/75 transition-colors hover:border-foreground/80"
          >
            X
          </a>
          {", "}
          <a
            href={GITHUB_URL}
            class="border-b border-foreground/50 pb-px text-foreground/75 transition-colors hover:border-foreground/80"
          >
            GitHub
          </a>
          {" or directly via "}
          <a
            href={`mailto:${CONTACT_EMAIL}`}
            class="border-b border-foreground/50 pb-px text-foreground/75 transition-colors hover:border-foreground/80"
          >
            Email
          </a>
          {"."}
        </p>
      </section>

      <!-- 3. Recent writing -->
      <section id="recent-writing" class="pt-8 pb-10">
        <div class="mb-1 flex items-center justify-between">
          <p
            class="text-[16px] font-medium tracking-[0.8px] text-foreground uppercase"
          >
            RECENT WRITING
          </p>
          <a
            href="/posts/"
            class="border-b border-foreground/30 pb-px text-[13px] text-foreground/65 transition-colors hover:border-foreground/60"
          >
            All posts →
          </a>
        </div>
        <ul>
          {
            recentPosts.map(post => (
              <li class="flex items-start justify-between gap-6 border-b border-border py-[14px]">
                <div class="min-w-0">
                  <a
                    href={`/posts/${post.id}/`}
                    class="text-[15px] font-medium text-foreground transition-colors hover:text-accent"
                  >
                    {post.data.title}
                  </a>
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="mt-1.5 flex flex-wrap gap-1.5">
                      {post.data.tags.map(tag => (
                        <a
                          href={`/tags/${slugifyStr(tag)}/`}
                          class="rounded-sm bg-muted px-2 py-0.5 text-[12px] text-foreground/50 transition-colors hover:text-foreground/70"
                        >
                          {tag}
                        </a>
                      ))}
                    </div>
                  )}
                </div>
                <time
                  datetime={post.data.pubDatetime.toISOString()}
                  class="mt-0.5 ml-4 shrink-0 text-[13px] whitespace-nowrap text-foreground/45"
                >
                  {fmtDate(post.data.pubDatetime)}
                </time>
              </li>
            ))
          }
        </ul>
      </section>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
