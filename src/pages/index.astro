---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { slugifyStr } from "@/utils/slugify";
import { Image } from "astro:assets";
import profileImg from "@/assets/images/profile-sebastian-eumann.png";

// ── Editable content ──────────────────────────────────────────────────────────
const HEADLINE =
  "Enterprise AI is an infrastructure challenge. Let's get it solved!";
const CONTACT_EMAIL = "sebastian@inferops.dev";
const GITHUB_URL = "https://github.com/sebeumann";
const X_URL = "https://x.com/sebeumann";
// ─────────────────────────────────────────────────────────────────────────────

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const recentPosts = sortedPosts.slice(0, 5);

function fmtDate(date: Date): string {
  return new Date(date).toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
  });
}
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <div class="mx-auto max-w-[680px]">
      <!-- 1. Hero -->
      <section id="hero" class="border-b border-border pt-12 pb-10">
        <div class="flex items-start justify-between gap-6">
          <div class="flex-1">
            <h1
              class="mb-4 text-[22px] font-medium tracking-[-0.3px] text-foreground"
            >
              {HEADLINE}
            </h1>
            <p class="mb-5 text-[15px] leading-[1.7] text-foreground/65">
              {
                "Every enterprise is building AI. Models and agents are just commodity. It's the infrastructure that serves and keeps them alive and effective. It is all about reliable operations, and the architecture decisions that compound over years. MLOps, LLMOps, inference infrastructure, platform engineering. This blog and my practice is about getting those parts right, with the depth and rigor they deserve."
              }
            </p>
            <div class="flex gap-5 text-[13px]">
              <a
                href={GITHUB_URL}
                class="border-b border-foreground/30 pb-px text-foreground/65 transition-colors hover:border-foreground/60"
              >
                GitHub
              </a>
              <a
                href={X_URL}
                class="border-b border-foreground/30 pb-px text-foreground/65 transition-colors hover:border-foreground/60"
              >
                X
              </a>
              <a
                href={`mailto:${CONTACT_EMAIL}`}
                class="border-b border-foreground/30 pb-px text-foreground/65 transition-colors hover:border-foreground/60"
              >
                Email
              </a>
            </div>
          </div>
          <Image
            src={profileImg}
            alt="Profile photo"
            width={212}
            height={212}
            class="-mt-1 hidden h-53 w-53 shrink-0 rounded-full object-cover sm:block"
          />
        </div>
      </section>

      <!-- 2. Work with me -->
      <section id="work-with-me" class="border-b border-border pt-8 pb-10">
        <p
          class="mb-4 text-[16px] font-medium tracking-[0.8px] text-foreground uppercase"
        >
          WORK WITH ME
        </p>
        <p class="mb-4 text-[15px] leading-[1.7] text-foreground/65">
          {
            "Most enterprise AI projects because critical infrastructure decisions get made under pressure, without enough context, and with consequences that only surface months later. I help technical teams and their leadership get ahead of that. Inference hosting strategy, platform architecture, the build-vs-buy decisions that lock in your AI roadmap for years."
          }
        </p>
        <p class="mb-4 text-[15px] leading-[1.7] text-foreground/65">
          {
            "Real confidence comes from building, not just planning. That's why I work hands-on when it matters: architecture design, reference implementations, PoCs, demonstrators, and production-ready systems. Kubernetes, GPU infrastructure, model serving, ML pipelines. You walk away not just with a working solution, but with the clarity to own it, defend it, and evolve it on your terms."
          }
        </p>
        <p class="text-[15px] leading-[1.7] text-foreground/65">
          {"Feel free to reach out on "}
          <a
            href={X_URL}
            class="border-b border-foreground/50 pb-px text-foreground/75 transition-colors hover:border-foreground/80"
          >
            X
          </a>
          {", "}
          <a
            href={GITHUB_URL}
            class="border-b border-foreground/50 pb-px text-foreground/75 transition-colors hover:border-foreground/80"
          >
            GitHub
          </a>
          {" or directly via "}
          <a
            href={`mailto:${CONTACT_EMAIL}`}
            class="border-b border-foreground/50 pb-px text-foreground/75 transition-colors hover:border-foreground/80"
          >
            Email
          </a>
          {"."}
        </p>
      </section>

      <!-- 3. Recent writing -->
      <section id="recent-writing" class="pt-8 pb-10">
        <div class="mb-1 flex items-center justify-between">
          <p
            class="text-[16px] font-medium tracking-[0.8px] text-foreground uppercase"
          >
            RECENT WRITING
          </p>
          <a
            href="/posts/"
            class="border-b border-foreground/30 pb-px text-[13px] text-foreground/65 transition-colors hover:border-foreground/60"
          >
            All posts →
          </a>
        </div>
        <ul>
          {
            recentPosts.map(post => (
              <li class="flex items-start justify-between gap-6 border-b border-border py-[14px]">
                <div class="min-w-0">
                  <a
                    href={`/posts/${post.id}/`}
                    class="text-[15px] font-medium text-foreground transition-colors hover:text-accent"
                  >
                    {post.data.title}
                  </a>
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="mt-1.5 flex flex-wrap gap-1.5">
                      {post.data.tags.map(tag => (
                        <a
                          href={`/tags/${slugifyStr(tag)}/`}
                          class="rounded-sm bg-muted px-2 py-0.5 text-[12px] text-foreground/50 transition-colors hover:text-foreground/70"
                        >
                          {tag}
                        </a>
                      ))}
                    </div>
                  )}
                </div>
                <time
                  datetime={post.data.pubDatetime.toISOString()}
                  class="mt-0.5 ml-4 shrink-0 text-[13px] whitespace-nowrap text-foreground/45"
                >
                  {fmtDate(post.data.pubDatetime)}
                </time>
              </li>
            ))
          }
        </ul>
      </section>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
