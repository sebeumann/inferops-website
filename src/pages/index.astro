---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { slugifyStr } from "@/utils/slugify";

// ── Editable content ──────────────────────────────────────────────────────────
const HEADLINE = "Building reliable AI infrastructure.";
const CONTACT_EMAIL = "hubert@inferops.dev";
const GITHUB_URL = "#"; // TODO: replace with real URL
const X_URL = "#"; // TODO: replace with real URL
// ─────────────────────────────────────────────────────────────────────────────

const posts = await getCollection("blog");
const sortedPosts = getSortedPosts(posts);
const recentPosts = sortedPosts.slice(0, 5);

function fmtDate(date: Date): string {
  return new Date(date).toLocaleDateString("en-US", {
    month: "short",
    day: "numeric",
  });
}
---

<Layout>
  <Header />
  <main id="main-content" data-layout="index" class="app-layout">
    <div class="mx-auto max-w-[680px]">
      <!-- 1. Hero -->
      <section id="hero" class="border-border border-b pt-12 pb-10">
        <h1
          class="text-foreground mb-4 text-[22px] font-medium tracking-[-0.3px]"
        >
          {HEADLINE}
        </h1>
        <p class="text-foreground/65 mb-5 text-[15px] leading-[1.7]">
          {"I'm "}
          <span class="text-foreground font-medium">Hubert</span>
          {
            " — an MLOps and AI infrastructure engineer. I write about the systems behind production ML: model serving, inference pipelines, platform engineering, and operational patterns that hold up under real workloads."
          }
        </p>
        <div class="flex gap-5 text-[13px]">
          <a
            href={GITHUB_URL}
            class="text-foreground/65 border-foreground/30 hover:border-foreground/60 border-b pb-px transition-colors"
          >
            GitHub
          </a>
          <a
            href={X_URL}
            class="text-foreground/65 border-foreground/30 hover:border-foreground/60 border-b pb-px transition-colors"
          >
            X
          </a>
          <a
            href={`mailto:${CONTACT_EMAIL}`}
            class="text-foreground/65 border-foreground/30 hover:border-foreground/60 border-b pb-px transition-colors"
          >
            Email
          </a>
        </div>
      </section>

      <!-- 2. Work with me -->
      <section id="work-with-me" class="border-border border-b pt-8 pb-10">
        <p
          class="text-foreground/65 mb-4 text-[14px] font-medium uppercase tracking-[0.8px]"
        >
          WORK WITH ME
        </p>
        <p
          class="text-foreground/65 mb-4 max-w-[560px] text-[15px] leading-[1.7]"
        >
          {"I help engineering teams design, build, and operate ML platforms and inference infrastructure. Previous clients include "}
          <span class="text-foreground">Siemens</span>
          {", "}
          <span class="text-foreground">Bosch</span>
          {", and "}
          <span class="text-foreground">IT.NRW</span>
          {"."}
        </p>
        <p class="text-foreground/65 max-w-[560px] text-[15px] leading-[1.7]">
          {
            "If you're looking for hands-on support or advisory on AI infrastructure, reach out at "
          }
          <a
            href={`mailto:${CONTACT_EMAIL}`}
            class="text-foreground/75 border-foreground/50 hover:border-foreground/80 border-b pb-px transition-colors"
          >
            {CONTACT_EMAIL}
          </a>
          {"."}
        </p>
      </section>

      <!-- 3. Recent writing -->
      <section id="recent-writing" class="pt-8 pb-10">
        <div class="mb-1 flex items-center justify-between">
          <p
            class="text-foreground/65 text-[14px] font-medium uppercase tracking-[0.8px]"
          >
            RECENT WRITING
          </p>
          <a
            href="/posts/"
            class="text-foreground/65 border-foreground/30 hover:border-foreground/60 border-b pb-px text-[13px] transition-colors"
          >
            All posts →
          </a>
        </div>
        <ul>
          {
            recentPosts.map(post => (
              <li class="border-border flex items-start justify-between gap-6 border-b py-[14px]">
                <div class="min-w-0">
                  <a
                    href={`/posts/${post.id}/`}
                    class="text-foreground hover:text-accent text-[15px] font-medium transition-colors"
                  >
                    {post.data.title}
                  </a>
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="mt-1.5 flex flex-wrap gap-1.5">
                      {post.data.tags.map(tag => (
                        <a
                          href={`/tags/${slugifyStr(tag)}/`}
                          class="text-foreground/50 bg-muted hover:text-foreground/70 rounded-sm px-2 py-0.5 text-[12px] transition-colors"
                        >
                          {tag}
                        </a>
                      ))}
                    </div>
                  )}
                </div>
                <time
                  datetime={post.data.pubDatetime.toISOString()}
                  class="text-foreground/45 mt-0.5 ml-4 shrink-0 whitespace-nowrap text-[13px]"
                >
                  {fmtDate(post.data.pubDatetime)}
                </time>
              </li>
            ))
          }
        </ul>
      </section>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
