inferops.dev {
    root * /var/www/inferops.dev
    file_server
    encode gzip zstd

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        Content-Security-Policy "default-src 'self'; script-src 'self' analytics.inferops.dev; connect-src 'self' analytics.inferops.dev; img-src 'self' data:; style-src 'self' 'unsafe-inline';"
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
    }

    # Cache static assets aggressively
    @static path *.css *.js *.svg *.png *.jpg *.jpeg *.webp *.avif *.woff2 *.ico
    header @static Cache-Control "public, max-age=31536000, immutable"

    # Cache HTML pages with revalidation
    @html path *.html /
    header @html Cache-Control "public, max-age=3600, must-revalidate"

    handle_errors {
        rewrite * /404.html
        file_server
    }
}

analytics.inferops.dev {
    reverse_proxy localhost:3000
}
